// Firestore security rules for Medivoyage.
// Public landing-page users are not authenticated, so we allow only constrained
// CREATEs to the `leads` collection. Everything else is locked down.
//
// Deploy:
//   firebase deploy --only firestore:rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Waitlist leads written anonymously by the landing page form.
    match /leads/{leadId} {
      allow create: if
           request.resource.data.keys().hasOnly(
             ['name','email','phone','source','page','referrer','userAgent','createdAt']
           )
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() < 200
        && request.resource.data.email is string
        && request.resource.data.email.size() < 320
        && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')
        && request.resource.data.phone is string
        && request.resource.data.phone.size() < 40
        && request.resource.data.source is string
        && request.resource.data.source.size() < 40
        && request.resource.data.userAgent is string
        && request.resource.data.userAgent.size() < 1000;

      // Never let public clients read or modify leads — only the server
      // (Admin SDK, via service account) reads them. The Admin SDK bypasses
      // these rules, so the export script still works.
      allow read, update, delete: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
